---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Qraft',
  description = 'Genera códigos QR personalizados que extraen automáticamente los colores y el favicon de cualquier web. Gratis, sin servidor.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F5F0EA" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
